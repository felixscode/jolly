{
	"productName": "Jolly",
	"version": "0.1.0",
	"identifier": "com.jolly.desktop",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:5173"
	},
	"app": {
		"withGlobalTauri": false,
		"windows": [
			{
				"title": "Jolly",
				"width": 800,
				"height": 500,
				"resizable": true,
				"center": true,
				"url": "/app"
			}
		]
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
